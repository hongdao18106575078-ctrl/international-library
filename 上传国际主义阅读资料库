// ============================================

(function() {
    'use strict';

    const navButtons = document.querySelectorAll('.nav-btn');
    const sections = document.querySelectorAll('.discipline-section');

    // 切换学科显示
    function switchDiscipline(disciplineId) {
        // 更新按钮状态
        navButtons.forEach(btn => {
            btn.classList.toggle('active', btn.dataset.discipline === disciplineId);
        });

        // 更新内容区域
        sections.forEach(section => {
            const isTarget = section.id === disciplineId;
            section.classList.toggle('active', isTarget);
        });
    }

    // 绑定导航点击事件
    navButtons.forEach(btn => {
        btn.addEventListener('click', function() {
            const disciplineId = this.dataset.discipline;
            switchDiscipline(disciplineId);
            // 更新 URL hash
            history.pushState(null, '', '#' + disciplineId);
        });
    });

    // 页面加载时从 hash 恢复状态
    function initFromHash() {
        const hash = window.location.hash.replace('#', '');
        if (hash && document.getElementById(hash)) {
            switchDiscipline(hash);
        }
    }

    // 监听浏览器前进/后退
    window.addEventListener('hashchange', function() {
        const hash = window.location.hash.replace('#', '');
        if (hash && document.getElementById(hash)) {
            switchDiscipline(hash);
        }
    });

    // 初始化
    initFromHash();

})();

/* ============================================
   国际主义阅读资料库 · 样式表
   International Style — 简约、理性、开放
   ============================================ */

/* --- Reset & Base --- */
*, *::before, *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

:root {
    --red: #c8102e;
    --dark-red: #9e0b23;
    --gold: #d4a017;
    --cream: #f5f0e8;
    --off-white: #faf8f4;
    --charcoal: #2c2c2c;
    --dark-gray: #3d3d3d;
    --mid-gray: #6b6b6b;
    --light-gray: #d1cbc0;
    --border-gray: #e0d8cc;
    --tag-bg: #e8e2d6;
    --shadow: rgba(44, 44, 44, 0.08);
    --radius: 0;
    --transition: 0.25s ease;
}

html {
    scroll-behavior: smooth;
    font-size: 16px;
}

body {
    font-family: 'Noto Sans SC', 'PingFang SC', 'Microsoft YaHei', 'Heiti SC', sans-serif;
    background-color: var(--off-white);
    color: var(--charcoal);
    line-height: 1.7;
    -webkit-font-smoothing: antialiased;
}

a {
    color: var(--dark-red);
    text-decoration: none;
    transition: color var(--transition);
}
a:hover {
    color: var(--red);
    text-decoration: underline;
}

.container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 2rem;
}

/* --- Hero / Header --- */
.hero {
    background: linear-gradient(135deg, var(--red) 0%, var(--dark-red) 100%);
    color: #fff;
    padding: 4.5rem 0 3.5rem;
    position: relative;
    overflow: hidden;
}
.hero::after {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: repeating-linear-gradient(
        45deg,
        transparent,
        transparent 40px,
        rgba(255,255,255,0.03) 40px,
        rgba(255,255,255,0.03) 41px
    );
    pointer-events: none;
}
.logo {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.6rem;
}
.logo-icon {
    font-size: 2.8rem;
    line-height: 1;
}
.site-title {
    font-family: 'Noto Serif SC', 'SimSun', serif;
    font-size: 2.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
}
.subtitle {
    font-size: 1.05rem;
    font-weight: 300;
    letter-spacing: 0.3em;
    opacity: 0.85;
    margin-top: 0.3rem;
}
.description {
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.9;
    opacity: 0.75;
    margin-top: 1.2rem;
    max-width: 600px;
}

/* --- Navigation --- */
.discipline-nav {
    background: var(--charcoal);
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
}
.nav-wrapper {
    display: flex;
    flex-wrap: wrap;
    gap: 0;
    padding: 0;
}
.nav-btn {
    flex: 0 0 auto;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.65);
    font-family: 'Noto Sans SC', sans-serif;
    font-size: 0.88rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    padding: 0.9rem 1.6rem;
    cursor: pointer;
    transition: all var(--transition);
    border-bottom: 3px solid transparent;
    position: relative;
}
.nav-btn:hover {
    color: #fff;
    background: rgba(255,255,255,0.08);
}
.nav-btn.active {
    color: #fff;
    border-bottom-color: var(--gold);
    background: rgba(255,255,255,0.05);
}

/* --- Main Content --- */
.main-content {
    padding: 3rem 0 4rem;
}

.discipline-section {
    display: none;
    opacity: 0;
    transition: opacity 0.4s ease;
}
.discipline-section.active {
    display: block;
    opacity: 1;
}

.discipline-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: var(--dark-red);
    margin-bottom: 0.2rem;
    letter-spacing: 0.04em;
}
.discipline-subtitle {
    font-size: 0.95rem;
    color: var(--mid-gray);
    font-weight: 300;
    letter-spacing: 0.12em;
    margin-bottom: 2.2rem;
    padding-bottom: 1rem;
    border-bottom: 2px solid var(--border-gray);
}

/* --- Sub-discipline Cards --- */
.sub-disciplines {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
}

.sub-card {
    background: #fff;
    border: 1px solid var(--border-gray);
    padding: 1.5rem 1.6rem;
    transition: all var(--transition);
    position: relative;
}
.sub-card:hover {
    border-color: var(--gold);
    box-shadow: 4px 4px 0 rgba(212, 160, 23, 0.15);
    transform: translate(-1px, -1px);
}

.sub-title {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--charcoal);
    margin-bottom: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-gray);
    letter-spacing: 0.03em;
}

.resource-list {
    list-style: none;
    margin: 0;
    padding: 0;
}
.resource-list li {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 0.4rem 0;
    border-bottom: 1px dashed var(--border-gray);
    font-size: 0.92rem;
}
.resource-list li:last-child {
    border-bottom: none;
}
.resource-list li a {
    flex: 1;
}

.tag {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    color: var(--mid-gray);
    background: var(--tag-bg);
    padding: 0.08rem 0.5rem;
    margin-left: 0.5rem;
    flex-shrink: 0;
    text-transform: uppercase;
}

/* --- Footer --- */
.footer {
    background: var(--charcoal);
    color: rgba(255,255,255,0.7);
    padding: 3rem 0;
    text-align: center;
}
.footer-content {
    max-width: 600px;
    margin: 0 auto;
}
.footer-quote {
    font-family: 'Noto Serif SC', serif;
    font-size: 1.2rem;
    color: var(--gold);
    margin-bottom: 0.8rem;
    font-weight: 400;
}
.footer-motto {
    font-size: 0.85rem;
    letter-spacing: 0.15em;
    font-weight: 300;
    margin-bottom: 0.5rem;
}
.footer-license {
    font-size: 0.75rem;
    opacity: 0.5;
    letter-spacing: 0.05em;
}

/* --- Responsive --- */
@media (max-width: 768px) {
    .container { padding: 0 1.2rem; }
    .site-title { font-size: 2rem; }
    .subtitle { font-size: 0.85rem; letter-spacing: 0.2em; }
    .nav-btn { font-size: 0.8rem; padding: 0.7rem 1rem; }
    .discipline-title { font-size: 1.7rem; }
    .sub-disciplines { grid-template-columns: 1fr; }
    .hero { padding: 3rem 0 2.5rem; }
}

@media (max-width: 480px) {
    .nav-wrapper { justify-content: center; }
    .nav-btn { flex: 1 0 auto; text-align: center; font-size: 0.75rem; padding: 0.6rem 0.5rem; }
    .site-title { font-size: 1.6rem; }
    .logo-icon { font-size: 2rem; }
}
